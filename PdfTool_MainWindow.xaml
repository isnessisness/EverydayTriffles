<Window x:Class="PdfCompressTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="智能 PDF 统一尺寸与定比压缩系统" Height="420" Width="620" WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="任务：1. 所有页面统一至第一页尺寸  |  2. 指定比例压缩" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20" Foreground="#333333"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,15">
            <TextBox x:Name="TxtFilePath" Width="450" Height="32" IsReadOnly="True" VerticalContentAlignment="Center" Padding="5,0"/>
            <Button Content="浏览文件" Width="90" Height="32" Margin="10,0,0,0" Click="BtnSelectFile_Click" Cursor="Hand"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,10" VerticalAlignment="Center">
            <TextBlock Text="🎯 请选择目标压缩率：" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold"/>
            <ComboBox x:Name="CmbRatio" Width="260" Height="30" SelectedIndex="0" VerticalContentAlignment="Center" Margin="10,0,0,0" FontSize="14">
                <ComboBoxItem Content="100% (不压缩，仅统一尺寸)" Tag="1.0"/>
                <ComboBoxItem Content="压缩至原体积 80% (保留高画质)" Tag="0.8"/>
                <ComboBoxItem Content="压缩至原体积 60% (均衡压缩比)" Tag="0.6"/>
                <ComboBoxItem Content="压缩至原体积 40% (极限小体积)" Tag="0.4"/>
            </ComboBox>
        </StackPanel>

        <TextBox x:Name="TxtLog" Grid.Row="3" Margin="0,10,0,15" IsReadOnly="True" VerticalScrollBarVisibility="Auto" Background="#F8F9FA" Padding="8" FontFamily="Consolas"/>

        <Button x:Name="BtnProcess" Grid.Row="4" Content="🚀 开始处理所选任务" Height="48" FontSize="15" FontWeight="Bold" Click="BtnProcess_Click" Background="#0078D7" Foreground="White" Cursor="Hand" IsEnabled="False"/>
    </Grid>
</Window>
